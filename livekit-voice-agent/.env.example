# LiveKit Cloud Configuration
LIVEKIT_URL=https://your-livekit-cloud-url.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# FastAPI API Key(s) for authentication
# Multiple keys can be comma-separated
API_KEYS=api-key1,api-key2


# Qdrant Configuration (for Knowledge Base RAG)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_base_chunks

# OpenAI Configuration (for query embeddings)
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
