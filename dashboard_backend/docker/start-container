#!/usr/bin/env bash

set -e

if [ "$SUPERVISOR_PHP_USER" != "root" ] && [ "$SUPERVISOR_PHP_USER" != "sail" ]; then
    echo "You should set SUPERVISOR_PHP_USER to either 'sail' or 'root'."
    exit 1
fi

if [ ! -z "$WWWUSER" ]; then
    usermod -u "$WWWUSER" sail
fi

if [ ! -d /.composer ]; then
    mkdir /.composer
fi

chmod -R ugo+rw /.composer

# Keep generated documentation web-readable across container restarts and
# future Scribe generations.
umask 022
mkdir -p /var/www/html/storage/app/private/scribe
chmod 755 /var/www/html/storage/app/private/scribe || true
if [ -f /var/www/html/storage/app/private/scribe/openapi.yaml ]; then
    chmod 644 /var/www/html/storage/app/private/scribe/openapi.yaml || true
fi

if [ $# -gt 0 ]; then
    if [ "$SUPERVISOR_PHP_USER" = "root" ]; then
        exec "$@"
    else
        exec gosu "$WWWUSER" "$@"
    fi
else
    exec /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf
fi
